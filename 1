1.	TABLES
CREATE TABLE Customer ( Custid INT PRIMARY KEY,
Custname VARCHAR(50), Age INT,
Phone VARCHAR(15)
);

CREATE TABLE Loan ( Loanid INT PRIMARY KEY,
Amount INT, Custid INT, EMI INT,
FOREIGN KEY (Custid) REFERENCES Customer(Custid)
);



