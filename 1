3.	QUERIES

(a)	Loan > 50000 Customers
SELECT Custname
FROM Customer C, Loan L WHERE C.Custid = L.Custid AND Amount > 50000;
 
(b)	Customers with NO loan
SELECT Custid FROM Customer
WHERE Custid NOT IN (SELECT Custid FROM Loan);


(c)	Total Loans
SELECT COUNT(*) FROM Loan;



4.	PROCEDURE
DELIMITER $$

CREATE PROCEDURE GetLoan(IN id INT) BEGIN
SELECT Amount, Custid FROM Loan
WHERE Loanid = id; END $$

DELIMITER ;


CALL PROCEDURE
