3.	QUERIES

(a)	Add average column in mark_details
ALTER TABLE mark_details ADD average DOUBLE;

(b)	Months between DOB and today
SELECT reg_no, stu_name,
TIMESTAMPDIFF(MONTH, DOB, CURDATE()) AS Months
FROM stu_details;

(c)	Drop address column
ALTER TABLE stu_details DROP COLUMN address;

(d)	PROCEDURE for sum & average marks
 
DELIMITER $$

CREATE PROCEDURE CalcMarks() BEGIN
UPDATE mark_details
SET total = mark1 + mark2 + mark3, average = (mark1 + mark2 + mark3) / 3;
END $$ DELIMITER ;
Call Procedure:
CALL CalcMarks();
 
