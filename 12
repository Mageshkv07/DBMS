12)	1. TABLES
CREATE TABLE stu_details ( reg_no INT PRIMARY KEY, stu_name VARCHAR(50), DOB DATE,
address VARCHAR(100), city VARCHAR(50)
);

CREATE TABLE mark_details ( reg_no INT,
mark1 INT, mark2 INT, mark3 INT, total INT,
FOREIGN KEY (reg_no) REFERENCES stu_details(reg_no)
);


