15)	1. TABLES
CREATE TABLE Department ( Depno INT PRIMARY KEY,
Depname VARCHAR(50), Deplocation VARCHAR(50)
);

CREATE TABLE Employee ( Empno INT PRIMARY KEY,
Empname VARCHAR(50), DOJ DATE,
Salary DECIMAL(10,2),
Depno INT,
FOREIGN KEY (Depno) REFERENCES Department(Depno)
);


