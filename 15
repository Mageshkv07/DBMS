3.	QUERIES

(a)	Number of employees in each department (deptno desc)
SELECT Depno, COUNT(*) AS Total_Employees FROM Employee
GROUP BY Depno ORDER BY Depno DESC;

(b)	Departments having at least one employee
SELECT DISTINCT D.Depname
FROM Department D, Employee E WHERE D.Depno = E.Depno;

(c)	Employee name, DOJ and experience (years)
SELECT Empname, DOJ,
 
TIMESTAMPDIFF(YEAR, DOJ, CURDATE()) AS Years_Completed
FROM Employee;


