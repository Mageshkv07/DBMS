3. QUERIES 
(a)	Custid of customers who have BOTH HomeLoan and VehicleLoan 
SELECT Custid FROM HomeLoan 
INTERSECT 
SELECT Custid FROM VehicleLoan; 
 
(b)	Custid of customers who do NOT have any loan 
SELECT Custid 
FROM Customer 
WHERE Custid NOT IN ( 
  SELECT Custid FROM HomeLoan 
  UNION 
  SELECT Custid FROM VehicleLoan 
); 
(c)	VIEW (Customer id, name, total loan amount) 
CREATE VIEW LoanView AS SELECT c.Custid,   c.Custname, 
      h.Amount + v.Amount AS TotalLoan 
FROM Customer c 
JOIN HomeLoan h ON c.Custid = h.Custid 
JOIN VehicleLoan v ON c.Custid = v.Custid; 
View Output 
SELECT * FROM LoanView; 
(d) TRIGGER (Display HomeLoan details after insert) 
DELIMITER $$ 
 
CREATE TRIGGER ShowHomeLoan 
AFTER INSERT ON HomeLoan 
FOR EACH ROW 
BEGIN 
  SELECT NEW.HLoanid AS LoanID, 
         NEW.Amount AS LoanAmount, 
         NEW.Custid AS CustomerID; 
END $$ 
 
DELIMITER ; 
 
