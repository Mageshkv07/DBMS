3. QUERIES 
(a) User who accessed costliest book SELECT Name FROM User U, Book B WHERE U.Bookid = B.Bookid AND Price = (SELECT MAX(Price) FROM Book); 
(b) User id + count of books SELECT Userid, COUNT(*) FROM User GROUP BY Userid; 
(c) Books published by Wiley SELECT * FROM Book WHERE Publication='Wiley';

