3.	QUERIES

(a)	Orders handled by vendor V004 ordered by delivery date
SELECT *
FROM order_master WHERE Vencode = 'V004' ORDER BY Delv_date;

(b)	Orders placed between 01-Jan-2006 and 01-Jul-2006
SELECT *
FROM order_master
WHERE Delv_date BETWEEN '2006-01-01' AND '2006-07-01';

(c)	Pending orders
 
SELECT *
FROM order_master
WHERE Ordstatus = 'Pending';


4.	PROCEDURE (Leap Year Check – MySQL)
DELIMITER $$

CREATE PROCEDURE CheckLeapYear(IN yr INT) BEGIN
IF (yr % 400 = 0) OR (yr % 4 = 0 AND yr % 100 != 0) THEN SELECT 'LEAP YEAR' AS Result;
ELSE
SELECT 'NOT LEAP YEAR' AS Result; END IF;
END $$ DELIMITER ;
Call Procedure
CALL CheckLeapYear(2024);
