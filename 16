16)	1. TABLES
CREATE TABLE order_master ( Orderno INT PRIMARY KEY,
Vencode VARCHAR(10), Ordstatus VARCHAR(20), Delv_date DATE
);

CREATE TABLE order_detail ( Orderno INT,
Itemcode INT, Qty_ord INT, Qty_deld INT,
FOREIGN KEY (Orderno) REFERENCES order_master(Orderno)
);


