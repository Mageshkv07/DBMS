c. FUNCTION
DELIMITER $$

CREATE PROCEDURE Fibonacci(IN n INT)
 
BEGIN
DECLARE a INT DEFAULT 0; DECLARE b INT DEFAULT 1; DECLARE c INT;
DECLARE i INT DEFAULT 1;
SELECT a AS Fibonacci; WHILE i < n DO
SET c = a + b;
SELECT c AS Fibonacci; SET a = b;
SET b = c; SET i = i + 1;
END WHILE;

END $$ DELIMITER ;
Call Procedure
CALL Fibonacci(10);


