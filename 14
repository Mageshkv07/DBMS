14)	1. TABLES
CREATE TABLE Course ( Ccode INT PRIMARY KEY,
Course_name VARCHAR(50)
);

CREATE TABLE Student ( Rollno INT PRIMARY KEY, Name VARCHAR(50),
Coursecode INT, Mark1 INT, Mark2 INT,
FOREIGN KEY (Coursecode) REFERENCES Course(Ccode)
);


