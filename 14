4.	PL/SQL / MYSQL PROCEDURE
DELIMITER $$

CREATE PROCEDURE OddEven(IN num INT) BEGIN
IF num % 2 = 0 THEN
SELECT 'EVEN NUMBER' AS Result; ELSE
SELECT 'ODD NUMBER' AS Result; END IF;
END $$ DELIMITER ;
Call Procedure
CALL OddEven(10);
 
