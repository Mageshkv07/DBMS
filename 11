11)	1. TABLES
CREATE TABLE Department ( DeptID INT PRIMARY KEY,
Dept_Name VARCHAR(50), HoD VARCHAR(50)
);

CREATE TABLE Student ( Regno INT PRIMARY KEY, Name VARCHAR(50), Gender VARCHAR(10), DeptID INT,
FOREIGN KEY (DeptID) REFERENCES Department(DeptID)
);


