3.	QUERIES

(a)	View for CSE Department students
CREATE VIEW CSE_Dept AS SELECT *
FROM Student WHERE DeptID = 1;

(b)	Department-wise student count (descending order)
SELECT DeptID, COUNT(*) AS Total_Students FROM Student
GROUP BY DeptID
ORDER BY Total_Students DESC;

(c)	Student name with Department name and HoD
SELECT S.Name, D.Dept_Name, D.HoD
 
FROM Student S, Department D WHERE S.DeptID = D.DeptID;

