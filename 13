3.	QUERIES

(a)	Emp no, name, salary and experience ordered by salary (desc)
SELECT Empno, Ename, Sal,
TIMESTAMPDIFF(YEAR, DoJ, CURDATE()) AS Experience
FROM Employee ORDER BY Sal DESC;

(b)	Employees working in Marketing department
SELECT E.Ename
FROM Employee E, Department D WHERE E.Deptno = D.Deptno AND D.Dname = 'Marketing';
 
(c)	Employees born in current month
SELECT Ename FROM Employee
WHERE MONTH(DoB) = MONTH(CURDATE());


