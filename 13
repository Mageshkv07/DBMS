13)	1. TABLES
CREATE TABLE Department ( Deptno INT PRIMARY KEY, Dname VARCHAR(50),
Dloc VARCHAR(50)
);

CREATE TABLE Employee ( Empno INT PRIMARY KEY, Ename VARCHAR(50),
Job VARCHAR(50),
MgrId INT, DoB DATE, DoJ DATE,
Sal DECIMAL(10,2), Comm DECIMAL(10,2),
Deptno INT,
FOREIGN KEY (Deptno) REFERENCES Department(Deptno)
);


