(d)	PL/SQL
DELIMITER $$

CREATE PROCEDURE StudentReport() BEGIN
DECLARE done INT DEFAULT 0;
 
DECLARE rno INT;
DECLARE sname VARCHAR(50); DECLARE dpt VARCHAR(20); DECLARE t INT;

DECLARE cur CURSOR FOR
SELECT Regno, Name, Dept, Total FROM Marks;

DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
OPEN cur; read_loop: LOOP
FETCH cur INTO rno, sname, dpt, t;

IF done = 1 THEN LEAVE read_loop;
END IF;

SELECT rno AS Regno, sname AS Name, dpt AS Dept, t AS Total; END LOOP;

CLOSE cur; END $$

DELIMITER ;


Call Procedure:
CALL StudentReport();
 
