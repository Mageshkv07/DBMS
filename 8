3.	QUERIES

(a)	Add REORDER column with value 50
ALTER TABLE Product
ADD Reorder INT DEFAULT 50;

(b)	Sales Report
SELECT
S.Salesid, P.Prodid, P.Prodesc, S.Qty,
S.Qty * P.Price AS TotalAmount FROM Sales S
JOIN Product P
ON S.Prodid = P.Prodid;
 
(c)	Product ID in descending order of quantity ordered
SELECT
Prodid,
SUM(Qty) AS TotalQty FROM Sales
GROUP BY Prodid
ORDER BY TotalQty DESC;


