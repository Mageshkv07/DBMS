8)	1. TABLES
CREATE TABLE Product ( Prodid INT PRIMARY KEY,
Prodesc VARCHAR(50), Price DECIMAL(10,2),
Stock INT
);

CREATE TABLE Sales ( Salesid INT PRIMARY KEY,
Prodid INT, Qty INT,
FOREIGN KEY (Prodid) REFERENCES Product(Prodid)
);

