9)	1. TABLES
CREATE TABLE Member (
MemberCode INT PRIMARY KEY, MemberName VARCHAR(50), PhoneNo VARCHAR(15)
);

CREATE TABLE Book ( BookCode INT PRIMARY KEY,
CategoryCode INT, BookName VARCHAR(50), Cost DECIMAL(10,2)
);

CREATE TABLE Issue (
MemberCode INT, BookCode INT, IssueDate DATE, ReturnDate DATE,
FOREIGN KEY (MemberCode) REFERENCES Member(MemberCode), FOREIGN KEY (BookCode) REFERENCES Book(BookCode)
);


