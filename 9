3.	QUERIES

(a)	Members who took book on 8-10-2007
SELECT M.MemberName FROM Member M, Issue I
 
WHERE M.MemberCode = I.MemberCode AND I.IssueDate = '2007-10-08';


(b)	Member codes who took books worth more than 400
SELECT I.MemberCode FROM Issue I, Book B
WHERE I.BookCode = B.BookCode AND B.Cost > 400;

(c)	CURSOR
DELIMITER $$

CREATE PROCEDURE ShowLibrary() BEGIN
DECLARE done INT DEFAULT 0;
DECLARE mcode INT;
DECLARE mname VARCHAR(50);

DECLARE cur CURSOR FOR
SELECT MemberCode, MemberName FROM Member;

DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
OPEN cur; LOOP_FETCH: LOOP
FETCH cur INTO mcode, mname; IF done THEN
LEAVE LOOP_FETCH; END IF;

SELECT mcode, mname; END LOOP;

CLOSE cur; END $$

DELIMITER ;


Call Procedure:
CALL ShowLibrary();
 
